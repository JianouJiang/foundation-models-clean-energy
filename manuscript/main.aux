\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Clean Energy Foundation Model Deployment Framework (CEFMDF). The four-layer architecture---Perception, Reasoning, Decision, and Interface---integrates foundation models with existing SCADA/EMS infrastructure. Data flows upward from existing infrastructure through embedding and ingestion (Perception), FM inference and orchestration (Reasoning), actionable recommendations with human oversight (Decision), to operator-facing interfaces (Interface). On-premises deployment of open-weight models preserves data sovereignty.}}{78}{figure.7}\protected@file@percent }
\newlabel{fig:cefmdf}{{7}{78}{Clean Energy Foundation Model Deployment Framework (CEFMDF). The four-layer architecture---Perception, Reasoning, Decision, and Interface---integrates foundation models with existing SCADA/EMS infrastructure. Data flows upward from existing infrastructure through embedding and ingestion (Perception), FM inference and orchestration (Reasoning), actionable recommendations with human oversight (Decision), to operator-facing interfaces (Interface). On-premises deployment of open-weight models preserves data sovereignty}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Time-series benchmark: 7-day load prediction traces. Chronos (zero-shot) closely tracks the actual load pattern without any training on the target data.}}{79}{figure.8}\protected@file@percent }
\newlabel{fig:ts_benchmark}{{8}{79}{Time-series benchmark: 7-day load prediction traces. Chronos (zero-shot) closely tracks the actual load pattern without any training on the target data}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces LLM energy domain Q\&A evaluation (Qwen2.5-7B, 50 questions across 5 domains). (a)\nobreakspace  {}Direct LLM keyword match scores by energy domain, revealing uneven parametric knowledge (wind = 0.675, AI = 0.405). (b)\nobreakspace  {}Comparison of direct LLM vs.\ RAG-augmented scores on a 15-question subset; RAG improves performance in all domains except wind, where the LLM already has adequate knowledge.}}{79}{figure.9}\protected@file@percent }
\newlabel{fig:llm_qa}{{9}{79}{LLM energy domain Q\&A evaluation (Qwen2.5-7B, 50 questions across 5 domains). (a)~Direct LLM keyword match scores by energy domain, revealing uneven parametric knowledge (wind = 0.675, AI = 0.405). (b)~Comparison of direct LLM vs.\ RAG-augmented scores on a 15-question subset; RAG improves performance in all domains except wind, where the LLM already has adequate knowledge}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces VLM zero-shot solar panel inspection. (a)\nobreakspace  {}Accuracy and F1 scores for CLIP zero-shot variants vs.\ supervised baseline on the ELPV dataset. (b)\nobreakspace  {}Confusion matrix for CLIP ensemble prompts, showing strong bias toward the defective class.}}{80}{figure.10}\protected@file@percent }
\newlabel{fig:vlm_inspection}{{10}{80}{VLM zero-shot solar panel inspection. (a)~Accuracy and F1 scores for CLIP zero-shot variants vs.\ supervised baseline on the ELPV dataset. (b)~Confusion matrix for CLIP ensemble prompts, showing strong bias toward the defective class}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Deployment cost-performance Pareto frontier across all benchmark experiments. Points on the frontier represent strategies that are not dominated (no other strategy is both cheaper and higher-performing). Zero-shot FMs cluster in the moderate-cost, high-performance quadrant.}}{81}{figure.11}\protected@file@percent }
\newlabel{fig:pareto}{{11}{81}{Deployment cost-performance Pareto frontier across all benchmark experiments. Points on the frontier represent strategies that are not dominated (no other strategy is both cheaper and higher-performing). Zero-shot FMs cluster in the moderate-cost, high-performance quadrant}{figure.11}{}}
